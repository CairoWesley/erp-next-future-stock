# URL base do ERPNext (sem barra no final)
ERPNEXT_URL=http://localhost:8080

# Credenciais de API de um usuário com perfil System Manager
# Geradas em: User > {usuário} > API Access > Generate Keys
ERPNEXT_API_KEY=cole_sua_api_key_aqui
ERPNEXT_API_SECRET=cole_sua_api_secret_aqui

# Empresa padrão usada nos exemplos (opcional)
# Produção: ERPNEXT_COMPANY=Sua Empresa Ltda
# Teste:    ERPNEXT_COMPANY=TEST-CO Ltda
ERPNEXT_COMPANY=Minha Empresa

# Warehouse alvo padrão (precisa bater com abrev da Company)
# Produção: ERPNEXT_WAREHOUSE=Produtos Acabados - I
# Teste:    ERPNEXT_WAREHOUSE=Produtos Acabados - TC
ERPNEXT_WAREHOUSE=Produtos Acabados - I

# Módulo onde os DocTypes serão criados (default: Manufacturing)
ERPNEXT_MODULE=Manufacturing

# Timeout das requisições HTTP em segundos
ERPNEXT_HTTP_TIMEOUT=30

# Verificar certificado SSL (true/false) — desative apenas em ambientes locais com TLS auto-assinado
ERPNEXT_VERIFY_SSL=true

# ----- HubSpot (sync de produtos via Private App) -----
# Setup:
#   HubSpot → Settings → Integrations → Private Apps → Create
#   Nome: ERPNext Sync
#   Scopes (Data tab):
#     - crm.objects.products.read
#     - crm.objects.products.write
#   Cria → copia Access token (pat-na1-...)
HUBSPOT_ACCESS_TOKEN=cole_seu_private_app_token_aqui

# ----- ASAAS (gateway de pagamento + NF) -----
# Sandbox: https://sandbox.asaas.com/api/v3
# Prod:    https://api.asaas.com/v3
ASAAS_URL=https://api.asaas.com/v3
ASAAS_API_KEY=cole_sua_asaas_api_key_aqui

# ----- Metabase (BI / dashboards) -----
METABASE_URL=https://metabase.suaempresa.com.br
METABASE_USERNAME=
METABASE_PASSWORD=
# Conexão direta ao MariaDB do ERPNext (pra Metabase ler)
ERPNEXT_DB_HOST=
ERPNEXT_DB_PORT=3306
ERPNEXT_DB_NAME=
ERPNEXT_DB_USER=
ERPNEXT_DB_PASSWORD=
